		"postcss": "^8.5.10",
		"svelte": "^5.45.6",
		"svelte-check": "^4.3.4",
		"tailwindcss": "^3.4.17",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"vite": "^7.2.6",
