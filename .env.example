# Claude API Configuration
# Get your API key from https://console.anthropic.com/
ANTHROPIC_API_KEY=your_api_key_here

# MCP Server URLs (optional - auto-detected)
# PUBLIC_MCP_URL=http://localhost:8787
# PUBLIC_MCP_PRODUCTION_URL=https://mcp.vibeship.co

# =============================================================================
# X (Twitter) API Configuration
# Get your API keys from https://developer.x.com/en/portal/dashboard
# =============================================================================

# API Key and Secret (from your app's "Keys and tokens" page)
X_API_KEY=your_api_key_here
X_API_SECRET=your_api_secret_here

# Bearer Token (for app-only authentication - read tweets, metrics)
X_BEARER_TOKEN=your_bearer_token_here

# Access Token and Secret (for user authentication - if needed)
X_ACCESS_TOKEN=your_access_token_here
X_ACCESS_TOKEN_SECRET=your_access_token_secret_here
