# Spawner UI is the execution plane and local dashboard for the Spark stack.
# It does not own Telegram ingress and should not receive the Telegram bot token.
#
# Provider keys below are for local execution paths only.

# Claude API Configuration
# Get your API key from https://console.anthropic.com/
ANTHROPIC_API_KEY=your_api_key_here

# Multi-LLM Orchestrator provider keys
# Claude uses ANTHROPIC_API_KEY from above.
# Codex readiness:
OPENAI_API_KEY=your_openai_api_key_here
ZAI_API_KEY=your_zai_api_key_here
MINIMAX_API_KEY=your_minimax_api_key_here

# Optional OpenAI-compatible provider defaults
ZAI_BASE_URL=https://api.z.ai/api/coding/paas/v4
ZAI_MODEL=glm-5.1
MINIMAX_MODEL=MiniMax-M2.7

# Local Spark Telegram mission relay webhook
MISSION_CONTROL_WEBHOOK_URLS=http://127.0.0.1:8788/spawner-events
TELEGRAM_RELAY_SECRET=

# Hosted two-service deploys should keep this service private where possible.
# Example Railway callback:
# MISSION_CONTROL_WEBHOOK_URLS=http://spark-telegram-bot.railway.internal:8788/spawner-events
# Optional explicit self URL. If unset, hosted builds use PORT for local self-calls.
# SPAWNER_UI_SELF_URL=http://127.0.0.1:${PORT}
# Use the same long value in both services. Bot calls into Spawner with this key.
# SPARK_BRIDGE_API_KEY=
# Private browser/API access key for hosted Spawner UI. Bot also uses this for
# protected board/provider reads and preview checks.
# SPARK_UI_API_KEY=
# EVENTS_API_KEY and MCP_API_KEY remain supported for older event/control clients.
# MCP_API_KEY=

# Optional absolute local paths. The Spark installer writes these automatically.
# SPARK_WORKSPACE_ROOT=/absolute/path/to/.spark/workspaces
# SPAWNER_STATE_DIR=/absolute/path/to/.spark/state/spawner-ui
# Keep Spark-run missions inside SPARK_WORKSPACE_ROOT by default.
# Set to 1 only for trusted local development where Spawner may edit external project paths.
SPARK_ALLOW_EXTERNAL_PROJECT_PATHS=0

# MCP Server URLs (optional - auto-detected)
# PUBLIC_MCP_URL=http://localhost:8797
# PUBLIC_MCP_PRODUCTION_URL=https://mcp.vibeship.co

# Local directory overrides (optional)
# SPAWNER_H70_SKILLS_DIR=../spark-skill-graphs
# H70_SKILLS_LAB_DIR=../spark-skill-graphs
# SPAWNER_TEAMS_DIR=./teams
# TEAM_REPO_TEAMS_DIR=./teams
# PUBLIC_H70_SKILLS_LAB_PATH=h70-skills-lab

# =============================================================================
# X (Twitter) API Configuration
# Get your API keys from https://developer.x.com/en/portal/dashboard
# =============================================================================

# API Key and Secret (from your app's "Keys and tokens" page)
X_API_KEY=your_api_key_here
X_API_SECRET=your_api_secret_here

# Bearer Token (for app-only authentication - read tweets, metrics)
X_BEARER_TOKEN=your_bearer_token_here

# Access Token and Secret (for user authentication - if needed)
X_ACCESS_TOKEN=your_access_token_here
X_ACCESS_TOKEN_SECRET=your_access_token_secret_here
