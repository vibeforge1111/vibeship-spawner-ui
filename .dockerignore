add-*.cjs
check-*.cjs
diagnose-*.cjs
direct-*.cjs
migrate-*.cjs
test-*.cjs
test-*.js
test-*.mjs

# Office documents (planning artefacts; not runtime)
*.docx
*.pdf

# Editor/IDE
.vscode
.idea
*.swp

# Local logs
*.log
svelte-check-output.txt
